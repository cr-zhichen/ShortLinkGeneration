{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:9000"
      }
    }
  },
  "ConnectionStrings": {
    "ShortLinkContext": "Server=[服务器ip];Port=3306;Database=[数据库名];User=[用户名];Password=[密码];"
  },
  "TokenOptions": {
    "SecretKey": "[输入你的鉴权Key 随便填]",
    "Issuer": "[输入发行者，随便填]",
    "Audience": "[输入Audience，随便填]",
    "ExpireMinutes": 30
  },
  "SMTP": {
    "SmtpService": "[发件服务器地址]",
    "Port": 587,
    "SendEmail": "[发件人地址]",
    "SendPwd": "[发件密码]"
  }
}
