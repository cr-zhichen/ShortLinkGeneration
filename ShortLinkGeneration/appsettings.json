{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://*:9001"
      },
      "Http": {
        "Url": "http://*:9000"
      }
    }
  },
  "ConnectionStrings": {
    "ShortLinkContext": "server=[服务器ip];user id=[用户名];password=[密码];port=3306;database=[数据库名]"
  },
  "TokenOptions": {
    "SecretKey": "[输入你的鉴权Key 随便填]",
    "Issuer": "[输入发行者，随便填]",
    "Audience": "[输入Audience，随便填]",
    "ExpireMinutes": 30
  },
  "SMTP": {
    "SmtpService": "[发件服务器地址]",
    "Port": 587,
    "SendEmail": "[发件人地址]",
    "SendPwd": "[发件密码]"
  }
}
