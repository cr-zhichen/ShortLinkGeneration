{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Https": {
        "Url": "https://*:9001"
      },
      "Http": {
        "Url": "http://*:9000"
      }
    }
  },
  "ConnectionStrings": {
    "ShortLinkContext": "Server=127.0.0.1;Port=3306;Database=数据库名;User=用户名;Password=密码;"
  }
}
